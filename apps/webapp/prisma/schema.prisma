generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  checks Check[]

  @@map("users")
}

model Check {
  id            String   @id @default(uuid()) @db.Uuid
  title         String?
  platform      String?
  content       String
  source        String
  slackChannel  String?  @map("slack_channel")
  slackThreadTs String?  @map("slack_thread_ts")
  userId        String?  @map("user_id") @db.Uuid
  status        String   @default("processing")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User?          @relation(fields: [userId], references: [id])
  sections CheckSection[]

  @@map("checks")
}

model CheckSection {
  id           String   @id @default(uuid()) @db.Uuid
  checkId      String   @map("check_id") @db.Uuid
  sectionIndex Int      @map("section_index")
  content      String
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  check  Check        @relation(fields: [checkId], references: [id], onDelete: Cascade)
  issues CheckIssue[]

  @@map("check_sections")
}

model CheckIssue {
  id         String   @id @default(uuid()) @db.Uuid
  sectionId  String   @map("section_id") @db.Uuid
  category   String
  severity   String
  quote      String
  message    String
  suggestion String?
  ruleId     String?  @map("rule_id") @db.Uuid
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  section CheckSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  rule    ExpressionRule? @relation(fields: [ruleId], references: [id])

  @@map("check_issues")
}

model ExpressionRule {
  id           String   @id @default(uuid()) @db.Uuid
  ngExpression String   @map("ng_expression")
  okExpression String   @map("ok_expression")
  description  String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  issues CheckIssue[]

  @@map("expression_rules")
}

model KnowledgeItem {
  id              String                      @id @default(uuid()) @db.Uuid
  title           String
  sourceType      String                      @map("source_type")
  sourceUrl       String?                     @map("source_url")
  content         String
  embedding       Unsupported("vector(1536)")?
  sourceArticleId String?                     @unique @map("source_article_id") @db.Uuid
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                    @updatedAt @map("updated_at") @db.Timestamptz

  sourceArticle SourceArticle? @relation(fields: [sourceArticleId], references: [id])

  @@map("knowledge_items")
}

model Source {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  name      String
  url       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  articles SourceArticle[]

  @@map("sources")
}

model SourceArticle {
  id          String    @id @default(uuid()) @db.Uuid
  sourceId    String    @map("source_id") @db.Uuid
  title       String
  url         String
  publishedAt DateTime? @map("published_at") @db.Timestamptz
  imported    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  source        Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  knowledgeItem KnowledgeItem?

  @@map("source_articles")
}
